{
  "name": "pkgvault-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:create-admin": "tsx db/create-admin.ts",
    "db:migrate-sources": "node --import tsx scripts/migrate-sources.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test scripts/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.800.0",
    "@react-email/render": "^1.1.2",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.11",
    "clsx": "^2.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.6.0",
    "liquid-glass-react": "^1.1.1",
    "next": "^15.3.0",
    "postgres": "^3.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^6.12.3",
    "uuid": "^11.1.0",
    "uuidv7": "^1.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "drizzle-kit": "^0.31.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "postcss": "^8.5.14"
  }
}

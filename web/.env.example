# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://pkgvault:pkgvault_dev@localhost:5432/pkgvault

# Used by docker-compose.prod.yml for the Postgres container password AND to
# build the app's DATABASE_URL. REQUIRED in production (compose fails if unset).
# Must match the password embedded in DATABASE_URL above.
POSTGRES_PASSWORD=pkgvault_dev

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Better-Auth) ─────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-64-char-string
BETTER_AUTH_URL=http://localhost:3000

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxx

# ─── Cloudflare R2 ──────────────────────────────────────────
# Optional. Current default workflow is metadata-only; set these only if you
# re-enable first-party R2 uploads or R2 download sources.
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=pkgvault-files
R2_PUBLIC_URL=https://files.pkgvault.example.com

# ─── Cron ───────────────────────────────────────────────────
CRON_SECRET=change-me-to-a-random-cron-secret

# ─── Setup ──────────────────────────────────────────────────
# Token required to call POST /api/setup/first-admin (bootstrap the first admin).
# Leave UNSET to fully disable that route (recommended once an admin exists).
# Prefer the `npm run db:create-admin` CLI for normal operation.
# SETUP_TOKEN=change-me-to-a-random-setup-token

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

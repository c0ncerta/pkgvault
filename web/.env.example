# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://pkgvault:pkgvault_dev@localhost:5432/pkgvault

# Used by docker-compose.prod.yml for the Postgres container password AND to
# build the app's DATABASE_URL. REQUIRED in production (compose fails if unset).
# Must match the password embedded in DATABASE_URL above.
POSTGRES_PASSWORD=pkgvault_dev

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Better-Auth) ─────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-64-char-string
BETTER_AUTH_URL=http://localhost:3000

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxx

# ─── Cron ───────────────────────────────────────────────────
CRON_SECRET=change-me-to-a-random-cron-secret

# ─── Setup ──────────────────────────────────────────────────
# Token required to call POST /api/setup/first-admin (bootstrap the first admin).
# Leave UNSET to fully disable that route (recommended once an admin exists).
# Prefer the `npm run db:create-admin` CLI for normal operation.
# SETUP_TOKEN=change-me-to-a-random-setup-token

# ─── Prowlarr (torrent meta-search) ─────────────────────────
# Powers the admin "Find torrent" search. PROWLARR_URL is the in-network
# address of the Prowlarr container; the API key is generated by Prowlarr on
# first run (config.xml). Add indexers (e.g. RuTracker) in the Prowlarr UI.
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

# ─── Mullvad VPN (gluetun → FlareSolverr egress) ────────────
# FlareSolverr routes through gluetun so geo/IP-blocked indexers (RuTracker)
# are reached via the VPN. Get the WireGuard key + address from your Mullvad
# account → WireGuard configuration. gluetun is kill-switch by default.
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32
SERVER_COUNTRIES=Netherlands

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
